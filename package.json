{
  "name": "datum",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@11.5.0",
  "engines": { "node": ">=22" },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:reset": "pnpm --filter @datum/db reset",
    "db:migrate": "pnpm --filter @datum/db migrate",
    "db:seed": "pnpm --filter @datum/db seed",
    "db:types": "pnpm --filter @datum/db types"
  },
  "devDependencies": {
    "turbo": "^2.1.0",
    "typescript": "^5.6.0"
  }
}
