{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "jsx": "react-native",
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "noEmit": true,
    "paths": {
      "@/*": ["./*"],
      "@datum/types": ["../../packages/types/src"],
      "@datum/types/*": ["../../packages/types/src/*"],
      "@datum/db": ["../../packages/db/src"],
      "@datum/db/*": ["../../packages/db/src/*"]
    },
    "types": ["react-native"]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "expo-env.d.ts",
    ".expo/types/**/*.ts"
  ]
}
