{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "noEmit": true,
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"],
      "@datum/types": ["../../packages/types/src"],
      "@datum/types/*": ["../../packages/types/src/*"],
      "@datum/db": ["../../packages/db/src"],
      "@datum/db/*": ["../../packages/db/src/*"],
      "@datum/core": ["../../packages/core/src"],
      "@datum/core/*": ["../../packages/core/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", ".next"]
}
