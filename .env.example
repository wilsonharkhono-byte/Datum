# Supabase (get these from https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # server-only; do not commit

# Expo client (read at build time)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# CI / scripts (optional)
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.YOUR-PROJECT.supabase.co:5432/postgres

# Anthropic API (chat assistant). Set in .env locally; CI reads from secrets.
ANTHROPIC_API_KEY=sk-ant-...

# Trello API — needed only for the import-trello-attachments script
# Get from https://trello.com/power-ups/admin (Key) and the "Token" link there.
TRELLO_API_KEY=
TRELLO_API_TOKEN=
