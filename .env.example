# Supabase (get these from https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # server-only; do not commit

# Expo client (read at build time)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# CI / scripts (optional)
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.YOUR-PROJECT.supabase.co:5432/postgres

# Anthropic API (chat assistant). Set in .env locally; CI reads from secrets.
ANTHROPIC_API_KEY=sk-ant-...
# Optional — Claude model override. Defaults to claude-haiku-4-5-20251001.
# Use claude-sonnet-4-6 (or latest Sonnet) when you want richer reasoning
# at higher cost — e.g., for cross-project synthesis or once we add
# file/vision content reading.
ANTHROPIC_MODEL=

# Vercel Cron auth — REQUIRED for the analyze-attachments cron to run.
# Vercel sends "Authorization: Bearer $CRON_SECRET" to scheduled routes.
# Set this in the Vercel project's Environment Variables AND in local .env.
# Without it the cron route returns 401 and silently does nothing.
CRON_SECRET=

# Trello API — needed only for the import-trello-attachments script
# Get from https://trello.com/power-ups/admin (Key) and the "Token" link there.
TRELLO_API_KEY=
TRELLO_API_TOKEN=

# Sentry error tracking (optional; SDK no-ops when DSN is unset)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Only needed for source-map upload at build time (CI / Vercel):
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
