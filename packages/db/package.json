{
  "name": "@datum/db",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint configured yet'",
    "migrate": "cd supabase && supabase db push",
    "reset": "cd supabase && supabase db reset --linked",
    "types": "supabase gen types typescript --linked 2>/dev/null > src/types.generated.ts",
    "seed": "tsx scripts/seed-pilot.ts",
    "seed:cards": "tsx scripts/seed-cards.ts",
    "seed:developments": "tsx scripts/seed-developments.ts",
    "import:trello": "tsx scripts/import-trello.ts",
    "import:trello-attachments": "tsx scripts/import-trello-attachments.ts",
    "import:trello-fetch": "tsx scripts/fetch-trello.ts",
    "import:trello-normalize": "tsx scripts/normalize-raw.ts",
    "test": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "supabase": "^1.200.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@datum/types": "workspace:*",
    "@supabase/supabase-js": "^2.45.0",
    "dotenv": "^17.4.2"
  }
}
