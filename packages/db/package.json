{
  "name": "@datum/db",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint configured yet'",
    "migrate": "cd supabase && supabase db push",
    "reset": "cd supabase && supabase db reset --linked",
    "types": "supabase gen types typescript --linked 2>/dev/null > src/types.generated.ts",
    "seed": "tsx scripts/seed-pilot.ts"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "supabase": "^1.200.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@datum/types": "workspace:*",
    "@supabase/supabase-js": "^2.45.0",
    "dotenv": "^17.4.2"
  }
}
